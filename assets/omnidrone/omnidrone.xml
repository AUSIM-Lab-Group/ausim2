<mujoco model="omnidrone">
  <option integrator="RK4" density="1.225" viscosity="1.8e-5"/>

  <compiler inertiafromgeom="false" meshdir="assets" autolimits="true"/>

  <default>
    <default class="omnidrone">
      <default class="visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom group="3" type="mesh"/>
      </default>
      <site group="5"/>
    </default>
  </default>

  <asset>
    <material name="matte_black" rgba="0.05 0.05 0.05 1" specular="0.02" shininess="0.05" reflectance="0"/>

    <mesh file="pavo20.STL"/>
  </asset>

  <worldbody>
    <body name="omnidrone" pos="0 0 0.03" childclass="omnidrone">
      <freejoint/>
      <inertial pos="0 0 0" mass="0.174" diaginertia="5.57e-5 5.57e-5 9.78e-5"/>
      <camera name="track" pos="-1 0 0.5" xyaxes="0 -1 0 1 0 2" mode="trackcom"/>

      <!-- Recenter the STL so the body frame sits near the mesh center. -->
      <geom mesh="pavo20" material="matte_black" class="visual" pos="-0.0673286 -0.0673286 -0.0250250"/>
      <geom mesh="pavo20" class="collision" pos="-0.0673286 -0.0673286 -0.0250250"/>

      <site name="imu"/>
      <site name="actuation"/>
      <site name="motor1_site" pos="0.0325 0.0325 -0.02"/>
      <site name="motor2_site" pos="0.0325 -0.0325 -0.02"/>
      <site name="motor3_site" pos="-0.0325 -0.0325 -0.02"/>
      <site name="motor4_site" pos="-0.0325 0.0325 -0.02"/>
    </body>
  </worldbody>

  <actuator>
    <motor class="omnidrone" ctrlrange="0 1" gear="0 0 0.933912 0 0 -4.63141e-03" site="motor1_site" name="motor1"/>
    <motor class="omnidrone" ctrlrange="0 1" gear="0 0 0.933912 0 0 4.63141e-03" site="motor2_site" name="motor2"/>
    <motor class="omnidrone" ctrlrange="0 1" gear="0 0 0.933912 0 0 -4.63141e-03" site="motor3_site" name="motor3"/>
    <motor class="omnidrone" ctrlrange="0 1" gear="0 0 0.933912 0 0 4.63141e-03" site="motor4_site" name="motor4"/>
  </actuator>

  <sensor>
    <gyro name="body_gyro" site="imu"/>
    <accelerometer name="body_linacc" site="imu"/>
    <framequat name="body_quat" objtype="site" objname="imu"/>
  </sensor>
</mujoco>
